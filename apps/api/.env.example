# Server
PORT=4000

# thirdweb Auth
THIRDWEB_SECRET_KEY=
THIRDWEB_ADMIN_PRIVATE_KEY=
AUTH_DOMAIN=localhost:3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# For scripts/db-reset.ts: Direct Postgres connection (Dashboard → Database → Connection string URI)
# DATABASE_URL=

# AVE Cloud API (market data)
MARKETDATA_API_KEY=
EVM_SIGNER_PRIVATE_KEY=
SOLANA_SIGNER_PRIVATE_KEY=
# Default chain for price queries (bsc, eth, solana, base) — AVE does not
# support Mantle directly; used only for non-Mantle market data lookups.
MARKETDATA_DEFAULT_CHAIN=bsc

# --- Mantle Network -----------------------------------------------------
# testnet = Mantle Sepolia Testnet (chainId 5003), mainnet = Mantle Mainnet (chainId 5000)
MANTLE_NETWORK=testnet
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz

# ERC-8004 registries (Mantle Testnet — VERIFY chain on explorer before mainnet switch)
MANTLE_IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
MANTLE_REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
MANTLE_ATTESTATION_REGISTRY_ADDRESS=

# Mock ERC20 tokens deployed by us on Mantle Testnet (see packages/contracts)
MANTLE_USDC_ADDRESS=
MANTLE_USDT_ADDRESS=
MANTLE_WMNT_ADDRESS=

# RealClaw / Byreal Skills CLI (Mantle DEX execution — Plan B1, Agentic Economy track)
# See apps/api/src/services/realclaw-executor.ts — confirm against openclaw.mantle.xyz docs
REALCLAW_API_BASE=https://openclaw.mantle.xyz/api
REALCLAW_API_KEY=

# Parallel AI (FX news search, Conversation Agent)
PARALLEL_API_KEY=

# Firecrawl (governance scraping for Conversation Agent)
FIRECRAWL_API_KEY=

# xAI Grok (X/social sentiment for Conversation Agent)
XAI_API_KEY=

# Gemini (LLM for trading signals + conversation agent)
GEMINI_CLI_AUTH_TYPE=oauth-personal
# Model for trading signal analysis (default: gemini-2.5-flash)
LLM_MODEL=gemini-2.5-flash

# Dune SIM (portfolio balances)
DUNE_SIM_API_KEY=

# App
CORS_ORIGIN=http://localhost:3000
# Public base URL used in 8004 metadata service links (optional)
PUBLIC_API_BASE_URL=http://localhost:4000
# n8n orchestration canvas
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_BRIDGE_API_KEY_SECRET=
# n8n basic auth (used by docker-compose)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=password
# n8n editor/webhook URLs
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678
# Attestation signing secret (for TEE-ready attestation flow)
ATTESTATION_SECRET=

# ERC-8004 PoC scripts (optional — only needed for scripts/erc8004/)
# Two-wallet pattern: owner mints NFT, server wallet gives feedback
TEST_OWNER_KEY=
TEST_SERVER_KEY=

# SelfClaw (human-backed agent verification)
# SELFCLAW_API_URL defaults to https://selfclaw.ai
SELFCLAW_API_URL=https://selfclaw.ai
# 32-byte hex key for encrypting Ed25519 private keys at rest (generate with: openssl rand -hex 32)
SELFCLAW_ENCRYPTION_KEY=

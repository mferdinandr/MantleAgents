# WalletConnect project id (free from https://cloud.walletconnect.com).
# Optional — if unset, the WalletConnect connector is omitted and injected
# (MetaMask) + Coinbase Wallet still work.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_N8N_BASE_URL=http://localhost:5678
NEXT_PUBLIC_MANTLE_NETWORK=testnet
